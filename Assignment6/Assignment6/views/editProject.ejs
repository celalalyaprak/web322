<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Edit Project</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>

<%- include('partials/navbar', { page: '/solutions/editProject' }) %>

<div class="container mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-4">Edit Project – <%= project.title %></h1>

  <form action="/solutions/editProject" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <input type="hidden" name="id" value="<%= project.id %>">

    <input type="text" name="title" value="<%= project.title %>" placeholder="Title" class="border p-2 rounded">
    <input type="text" name="feature_img_url" value="<%= project.feature_img_url %>" placeholder="Feature Image URL" class="border p-2 rounded">

    <textarea name="intro_short" placeholder="Intro Short" class="border p-2 rounded"><%= project.intro_short %></textarea>
    <textarea name="summary_short" placeholder="Summary Short" class="border p-2 rounded"><%= project.summary_short %></textarea>
    <textarea name="impact" placeholder="Impact" class="border p-2 rounded"><%= project.impact %></textarea>

    <input type="text" name="original_source_url" value="<%= project.original_source_url %>" placeholder="Original Source URL" class="border p-2 rounded">

    <div class="col-span-2 flex gap-4">
      <button type="submit" class="bg-blue-500 text-white px-4 py-2 rounded">Update Project</button>
      <a href="/solutions/deleteProject/<%= project.id %>" class="text-red-500 underline">Delete Project</a>
    </div>
  </form>
</div>

</body>
</html>
