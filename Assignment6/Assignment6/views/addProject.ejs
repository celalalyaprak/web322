<script src="https://cdn.tailwindcss.com"></script>
<%- include('partials/navbar') %>

<h2 class="text-2xl font-bold mb-4">Add Project</h2>

<form method="POST" action="/solutions/addProject" class="space-y-4">
    <div class="flex flex-wrap gap-4">
        <input type="text" name="title" placeholder="Title" class="border-b border-gray-500 focus:outline-none w-1/5">
        <input type="text" name="featureImage" placeholder="Feature Image URL" class="border-b border-gray-500 focus:outline-none w-1/5">
        <textarea name="intro" placeholder="Intro Short" class="border-b border-gray-500 focus:outline-none w-1/5"></textarea>
        <textarea name="summary" placeholder="Summary Short" class="border-b border-gray-500 focus:outline-none w-1/5"></textarea>
        <textarea name="impact" placeholder="Impact" class="border-b border-gray-500 focus:outline-none w-1/5"></textarea>
        <input type="text" name="originalSource" placeholder="Original Source URL" class="border-b border-gray-500 focus:outline-none w-1/5">
    </div>

    <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded">Submit</button>
</form>
