<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>User History</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-900 text-gray-300 min-h-screen">

  <%- include('partials/navbar', { page: '/userHistory' }) %>

  <div class="container mx-auto px-4 py-8">
    <div class="hero mb-6 bg-gray-800 p-6 rounded shadow text-center">
      <h1 class="text-3xl font-bold mb-2"><%= session.user.userName %></h1>
      <p>User History: <%= session.user.email %></p>
    </div>

    <div class="overflow-x-auto">
      <table class="table table-zebra w-full bg-gray-800 rounded">
        <thead>
          <tr class="text-gray-400">
            <th>Login Date/Time</th>
            <th>Client Information</th>
          </tr>
        </thead>
        <tbody>
          <% session.user.loginHistory.forEach(history => { %>
            <tr>
              <td><%= history.dateTime %></td>
              <td><%= history.userAgent %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

</body>
</html>
