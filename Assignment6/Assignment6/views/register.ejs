<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Register</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdn.jsdelivr.net/npm/daisyui@4.4.18/dist/full.css" rel="stylesheet" type="text/css" />
</head>
<body class="bg-gray-900 text-gray-300 min-h-screen flex items-center justify-center">

  <div class="w-full max-w-md p-8 bg-gray-800 rounded shadow-lg">
    <h2 class="text-3xl font-bold text-center mb-4">Register</h2>
    <p class="text-center mb-6 text-gray-400">Please provide your credentials below</p>

    <% if (successMessage) { %>
      <div class="alert mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span><%= successMessage %></span>
      </div>
      <a href="/login" class="btn btn-success w-full">Proceed to Log in</a>
    <% } else { %>
      <form action="/register" method="POST" class="space-y-4">
        <div>
          <label class="block text-sm mb-1">User Name</label>
          <input type="text" name="userName" value="<%= userName %>" class="w-full px-3 py-2 rounded bg-gray-900 border border-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500" required>
        </div>

        <div>
          <label class="block text-sm mb-1">Password</label>
          <input type="password" name="password" class="w-full px-3 py-2 rounded bg-gray-900 border border-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500" required>
        </div>

        <div>
          <label class="block text-sm mb-1">Confirm Password</label>
          <input type="password" name="password2" class="w-full px-3 py-2 rounded bg-gray-900 border border-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500" required>
        </div>

        <div>
          <label class="block text-sm mb-1">Email Address</label>
          <input type="email" name="email" class="w-full px-3 py-2 rounded bg-gray-900 border border-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500" required>
        </div>

        <button type="submit" class="w-full bg-green-500 hover:bg-green-600 text-white py-2 rounded">Register</button>
      </form>

      <% if (errorMessage) { %>
        <div class="alert alert-error mt-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span><%= errorMessage %></span>
        </div>
      <% } %>
    <% } %>

  </div>

</body>
</html>
